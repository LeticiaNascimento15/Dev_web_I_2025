Rconsultar.php
<?php

require_once '../conexao.php';



try {

    $pdo = getPDO();



    $representante = $_POST['representante'];



    $sql = "

        SELECT

            A3_COD,
            A3_NOME

        FROM represen

        WHERE A3_COD = '$representante'

    ";



    $stmt = $pdo->prepare($sql);



    $stmt->execute();



    $dados = $stmt->fetchAll();



} catch(PDOException $erro) {

    echo $erro->getMessage();

}

?>

