        <th>Código</th>
        <th>Nome</th>

    </tr>

    <?php

    foreach($dados as $linha) {

        echo "<tr>";

        echo "<td>" . $linha['A3_COD'] . "</td>";

        echo "<td>" . $linha['A3_NOME'] . "</td>";

        echo "</tr>";

    }

    ?>

</table>

