function getPDO():PDO {

    $host = 'localhost';
    $db = 'seubanco';
    $user = 'root';
    $pass = '';
    $charset = 'utf8mb4';



    $dsn = "mysql:host=$host;dbname=$db;charset=$charset";



    $options = [

        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,

        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,

        PDO::ATTR_PERSISTENT => true

    ];



    try {

        return new PDO(
            $dsn,
            $user,
            $pass,
            $options
        );

    } catch(PDOException $erro) {

        die(
            "Erro conexão: " .
            $erro->getMessage()
        );

    }

}



$clientes = [];



if(isset($_POST['representante'])) {

    $representante = trim($_POST['representante']);



    if(!empty($representante)) {

        $conexao = getPDO();



        $sql = "

            SELECT

                r.A3_COD,
                r.A3_NOME,

                c.A1_COD,
                c.A1_NOME

            FROM represen r

            LEFT JOIN pedidos p
                ON p.C5_VEND1 = r.A3_COD

            LEFT JOIN clientes c
                ON c.A1_COD = p.C5_CLIENTE

            WHERE r.A3_COD = :repres

            GROUP BY

                r.A3_COD,
                r.A3_NOME,

                c.A1_COD,
                c.A1_NOME

            ORDER BY c.A1_NOME

        ";



        $comando = $conexao->prepare($sql);



        $comando->bindParam(
            ':repres',
            $representante,
            PDO::PARAM_STR
        );



        $comando->execute();



        $clientes = $comando->fetchAll();

    }

}

