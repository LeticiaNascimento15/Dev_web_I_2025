<?php
require_once '../../util/funcoes.php';

$pdo = getPDO();

/* INSERIR */
if (isset($_POST['acao']) && $_POST['acao'] == 'salvar') {

    $sql = "INSERT INTO funcionario(nome,cargo,salario)
            VALUES(:NOME,:CARGO,:SALARIO)";

    $stmt = $pdo->prepare($sql);
    $stmt->bindValue(':NOME', $_POST['nome']);
    $stmt->bindValue(':CARGO', $_POST['cargo']);
    $stmt->bindValue(':SALARIO', $_POST['salario']);
    $stmt->execute();

    header("Location: funcionario.php");
    exit;
}

/* ALTERAR */
if (isset($_POST['acao']) && $_POST['acao'] == 'editar') {

    $sql = "UPDATE funcionario
            SET nome=:NOME,
                cargo=:CARGO,
                salario=:SALARIO
            WHERE id=:ID";

    $stmt = $pdo->prepare($sql);
    $stmt->bindValue(':NOME', $_POST['nome']);
    $stmt->bindValue(':CARGO', $_POST['cargo']);
    $stmt->bindValue(':SALARIO', $_POST['salario']);
    $stmt->bindValue(':ID', $_POST['id'], PDO::PARAM_INT);
    $stmt->execute();

    header("Location: funcionario.php");
    exit;
}

/* EXCLUIR */
if (isset($_GET['excluir'])) {

    $sql = "DELETE FROM funcionario WHERE id=:ID";

    $stmt = $pdo->prepare($sql);
    $stmt->bindValue(':ID', $_GET['excluir'], PDO::PARAM_INT);
    $stmt->execute();

    header("Location: funcionario.php");
    exit;
}

/* BUSCAR PARA EDIÇÃO */
$funcionarioEdicao = null;

if (isset($_GET['editar'])) {

    $sql = "SELECT * FROM funcionario WHERE id=:ID";

    $stmt = $pdo->prepare($sql);
    $stmt->bindValue(':ID', $_GET['editar'], PDO::PARAM_INT);
    $stmt->execute();

    $funcionarioEdicao = $stmt->fetch(PDO::FETCH_ASSOC);
}

/* LISTAR */
$sql = "SELECT * FROM funcionario ORDER BY id";
$stmt = $pdo->prepare($sql);
$stmt->execute();

$funcionarios = $stmt->fetchAll(PDO::FETCH_ASSOC);
?>

